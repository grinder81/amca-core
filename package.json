{
  "name": "amca-core",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "AMCA Core: proof-gated semantic governance kernel for agentic systems.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "amca": "tsx packages/cli/src/index.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:mission": "vitest run packages/testing/src/mission",
    "test:provider:live": "vitest run packages/provider-harness/src/live-provider-harness.test.ts packages/testing/src/mission/provider-harness-live-loop.mission.test.ts",
    "demo:flight-recorder": "tsx packages/testing/src/demo/flight-recorder.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
